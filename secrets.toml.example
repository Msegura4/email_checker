# ── .streamlit/secrets.toml ───────────────────────────────────────────────────
# Ce fichier est un EXEMPLE. Ne jamais commiter le fichier rempli.
# Sur Streamlit Cloud : coller ces valeurs dans Settings > Secrets

# Clé API Groq
GROQ_KEY = "gsk_..."

# Provider mail : "gmail" ou "imap"
MAIL_PROVIDER = "gmail"

# ── Config IMAP (si MAIL_PROVIDER = "imap") ───────────────────────────────────
IMAP_HOST     = "imap.gmail.com"
IMAP_PORT     = "993"
IMAP_USER     = "votre@email.com"
IMAP_PASSWORD = "votre_mot_de_passe"
IMAP_FOLDER   = "INBOX"
IMAP_USE_SSL  = "true"

# ── Gmail OAuth2 (si MAIL_PROVIDER = "gmail") ─────────────────────────────────
# Contenu complet de token.json sur UNE seule ligne (copier-coller le JSON)
GMAIL_TOKEN = '{"token": "...", "refresh_token": "...", "client_id": "...", ...}'

# Contenu complet de credentials.json sur UNE seule ligne
GMAIL_CREDENTIALS = '{"installed": {"client_id": "...", "client_secret": "...", ...}}'
